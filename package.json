{
  "name": "transactions-basic",
  "module": "main.ts",
  "type": "module",
  "private": true,
  "version": "1.0.0",
  "description": "CRUD con Arquitectura Hexagonal, Node.js, Express y Docker",
  "main": "main.ts",
  "scripts": {
    "start": "bun run src/main.ts",
    "dev": "bun run src/main.ts",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "latest",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.7.0",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "jest": "^30.4.2",
    "jiti": "^2.7.0",
    "prettier": "^3.8.3",
    "ts-jest": "^29.4.9",
    "typescript-eslint": "^8.59.3"
  },
  "peerDependencies": {
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "pg": "^8.20.0",
    "uuid": "^14.0.0"
  }
